# Cross-Boundary Data Type Enforcement Rule
# Detects violations of service/architecture boundary contracts
# Ensures types crossing boundaries use proper contract types (DTOs, Contracts)

RULE "CROSS-BOUNDARY-TYPE-ENFORCEMENT" : IMetaArchitecture
  ID: "ARCH-BOUNDARY-TYPES-001"
  DESCRIPTION: "Type crossing service/architecture boundary does not use required contract namespace"
  SEVERITY: Error
  CATEGORY: "Architecture_Quality"
  APPLIES_TO: ["cpp", "python", "java", "c"]

  PLUGIN:
    ID: "architecture-validator"
    SCOPE: "tree"
    CONFIG:
      validator: "CrossBoundaryType"
      boundary_patterns: "[{\"from\":\"tensorflow.python.*\",\"to\":\"tensorflow.core.*\",\"required_type_namespace\":\"*Proto\",\"message\":\"Python API should use Proto types when accessing core\"},{\"from\":\"tensorflow::ops::*\",\"to\":\"tensorflow::internal::*\",\"required_type_namespace\":\"tensorflow::*Def\",\"message\":\"Ops should use Def types when accessing internal\"},{\"from\":\"*\",\"to\":\"*.internal.*\",\"required_type_namespace\":\"tensorflow::*\",\"message\":\"Cross-boundary access should use public TensorFlow API\"}]"

  EDUCATION:
    DOCS_URL: "https://martinfowler.com/bliki/BoundedContext.html"
    WHY_IT_MATTERS: "This rule ensures that services communicate with each other using a consistent and well-defined interface, which is critical for maintaining the reliability, scalability, and performance of the system as a whole. When services use the same namespace for their contracts, they can easily find and use each other's APIs, making it easier to develop, test, and deploy the system. Additionally, using a consistent naming convention helps to reduce confusion and improve code readability, which is especially important in large and complex systems where multiple teams may be working on different parts of the system simultaneously"
    BUSINESS_IMPACT: "The business impact of violating this rule is that it can lead to confusion and errors in communication between different services or systems, which can result in delays, additional costs, and a negative impact on the customer experience. Additionally, the failure to use required contract namespaces can make it more difficult to maintain and update the system over time, leading to a higher risk of errors and downtime"
    QUICK_FIX: "Create contract types (DTOs or interfaces) in the required namespace (e.g., *.Contracts or *.DTOs). Update the code to use these contract types instead of directly referencing implementation types across boundaries. Apply the Dependency Inversion Principle to depend on abstractions, not concrete implementations."

  ARCHITECTURAL_CONTEXT:
    PROJECT_TYPE: "ML_FRAMEWORK"
    ARCHITECTURE_PATTERN: "Layered"
    DESIGN_PRINCIPLES: ["Language_Contracts", "Proto_Abstraction", "Language_Independence"]

  VIOLATIONS:
    - "Cross-boundary type violation: {{SOURCE_NAMESPACE}} → {{TARGET_NAMESPACE}} (required: {{REQUIRED_TYPE_NAMESPACE}})"
    - "Service boundary breach: Type in {{TARGET_NAMESPACE}} accessed from {{SOURCE_NAMESPACE}} without contract"
    - "Architectural boundary violation: Types crossing {{FROM_PATTERN}} → {{TO_PATTERN}} must use {{REQUIRED_TYPE_NAMESPACE}}"

END_RULE
