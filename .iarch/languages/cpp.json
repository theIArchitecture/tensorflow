{
  "language": "cpp",
  "display_name": "C++",
  "file_extensions": [".cpp", ".cc", ".cxx", ".hpp", ".hh", ".hxx", ".h"],
  "layer_detection": {
    "layers": {
      "PythonAPI": { "path_patterns": ["tensorflow/python"] },
      "CC_API":    { "path_patterns": ["tensorflow/cc"] },
      "C_API":     { "path_patterns": ["tensorflow/c/"] },
      "Lite":      { "path_patterns": ["tensorflow/lite"] },
      "Compiler":  { "path_patterns": ["tensorflow/compiler"] },
      "Core":      { "path_patterns": ["tensorflow/core"] }
    }
  },
  "parsing_patterns": {
    "scope_from_path": "tensorflow/([^/]+)/",
    "namespace": "^\\s*namespace\\s+([\\w:]+)\\s*\\{",
    "import": "^\\s*#include\\s*[<\"](?<module>[^>\"]+)[>\"]",
    "type_declaration": "^\\s*(?:template\\s*<[^>]*>\\s*)?(?:class|struct|enum(?:\\s+class)?)\\s+(\\w+)(?:\\s*(?:[:{]|:\\s*(?:public|protected|private)))",
    "type_keywords": ["class", "struct", "enum"],
    "method_declaration": "^\\s*(?:virtual\\s+)?(?:static\\s+)?(?:inline\\s+)?([\\w:]+(?:<[^>]+>)?)\\s+([\\w:]+)\\s*\\(([^)]*)\\)",
    "instantiation": "\\bnew\\s+([\\w:]+)(?:<[^>]*>)?\\s*\\(",
    "comment_single_line": "//(.*)$",
    "comment_multi_line": "/\\*(.*?)\\*/",
    "comment_documentation": "///(.*)$"
  },
  "formatting_rules": {
    "indent_size": 2,
    "increase_indent_triggers": ["{"],
    "decrease_indent_triggers": ["}"],
    "decrease_before_line": true
  },
  "syntax_validation": {
    "balanced_pairs": [
      { "open": "(", "close": ")" },
      { "open": "[", "close": "]" },
      { "open": "{", "close": "}" },
      { "open": "<", "close": ">" }
    ]
  },
  "comment_styles": ["//", "/*", "///"]
}
