{
  "language": "c",
  "display_name": "C",
  "file_extensions": [".c", ".h"],
  "layer_detection": {
    "layers": {
      "C_API": { "path_patterns": ["tensorflow/c/"] },
      "Core":  { "path_patterns": ["tensorflow/core"] }
    }
  },
  "parsing_patterns": {
    "scope_from_path": "tensorflow/([^/]+)/",
    "namespace": "",
    "import": "^\\s*#include\\s*[<\"](?<module>[^>\"]+)[>\"]",
    "type_declaration": "^\\s*(?:struct|enum|typedef)\\s+(\\w+)",
    "type_keywords": ["struct", "enum", "typedef"],
    "method_declaration": "^\\s*([\\w\\*]+)\\s+([\\w]+)\\s*\\(([^)]*)\\)",
    "comment_single_line": "//(.*)$",
    "comment_multi_line": "/\\*(.*?)\\*/",
    "comment_documentation": "///(.*)$"
  },
  "formatting_rules": {
    "indent_size": 2,
    "increase_indent_triggers": ["{"],
    "decrease_indent_triggers": ["}"],
    "decrease_before_line": true
  },
  "comment_styles": ["//", "/*", "///"]
}
