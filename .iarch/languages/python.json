{
  "language": "python",
  "display_name": "Python",
  "file_extensions": [".py", ".pyw", ".pyi"],

  "layer_detection": {
    "layers": {
      "PythonAPI": { "path_patterns": ["tensorflow/python"] },
      "Lite":      { "path_patterns": ["tensorflow/lite"] },
      "Compiler":  { "path_patterns": ["tensorflow/compiler"] },
      "Core":      { "path_patterns": ["tensorflow/core"] }
    }
  },

  "parsing_patterns": {
    "scope_from_path": "tensorflow/([^/]+)/",
    "namespace": "",
    "import": "^(?:import\\s+(?<module>[\\w\\.]+)(?:\\s+as\\s+(?<alias>\\w+))?|from\\s+(?<module>[\\w\\.]+)\\s+import\\s+(?<symbols>[\\w\\*, ]+)(?:\\s+as\\s+(?<alias>\\w+))?)",
    "type_declaration": "^(class)\\s+(\\w+)(?:\\(([^)]*)\\))?:",
    "type_keywords": ["class"],
    "method_declaration": "^(\\s*)def\\s+(\\w+)\\s*\\(([^)]*)\\)(?:\\s*->\\s*([\\w\\[\\],\\s]+))?:",
    "comment_single_line": "#(.*)$",
    "comment_multi_line": "",
    "comment_documentation": "\"\"\"(.*?)\"\"\""
  },

  "plain_import_behavior": "importModule",

  "transformation_rules": {
    "import_template": "import {namespace}",
    "import_insert_location": "after_last_import",
    "import_removal_pattern": "^\\s*(?:import\\s+{namespace}|from\\s+{namespace}\\s+import).*$"
  },

  "formatting_rules": {
    "indent_size": 4,
    "increase_indent_triggers": [":"],
    "decrease_indent_triggers": [],
    "decrease_before_line": false
  },

  "syntax_validation": {
    "balanced_pairs": [
      { "open": "(", "close": ")" },
      { "open": "[", "close": "]" },
      { "open": "{", "close": "}" }
    ],
    "invalid_patterns": ["^\\s*\\t\\s+"]
  },

  "comment_styles": ["#", "\"\"\""]
}
